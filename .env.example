# ---------------------------------------------------------------------------
# Environment variables
#
# Copy this file to `.env.local` and fill in real values for local development:
#   cp .env.example .env.local
#
# `.env.local` is git-ignored. This `.env.example` is committed and must list
# EVERY variable the app reads (see src/env.ts), with placeholder values only —
# never commit real secrets.
#
# Validation lives in src/env.ts. Variables prefixed NEXT_PUBLIC_ are exposed to
# the browser; all others are server-only.
# ---------------------------------------------------------------------------

# App ------------------------------------------------------------------------
# Canonical base URL of the app (no trailing slash).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase -------------------------------------------------------------------
# Project URL and public anon key (safe for the browser).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — server-only, full database access. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=""

# Sanity CMS -----------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
# Pin the API version to a date (YYYY-MM-DD) for stable, reproducible queries.
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"
# Read token for authenticated/preview content — server-only.
SANITY_API_READ_TOKEN=""

# Stripe ---------------------------------------------------------------------
# Publishable key (safe for the browser).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Secret key and webhook signing secret — server-only.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
