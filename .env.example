# ---------------------------------------------------------------------------
# Environment variables
#
# Copy this file to `.env.local` and fill in real values for local development:
#   cp .env.example .env.local
#
# `.env.local` is git-ignored. This `.env.example` is committed and must list
# EVERY variable the app reads (see src/env.ts), with placeholder values only —
# never commit real secrets.
#
# Validation lives in src/env.ts. Variables prefixed NEXT_PUBLIC_ are exposed to
# the browser; all others are server-only.
# ---------------------------------------------------------------------------

# App ------------------------------------------------------------------------
# Canonical base URL of the app (no trailing slash).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase -------------------------------------------------------------------
# Project URL and public anon key (safe for the browser).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — server-only, full database access. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=""

# Sanity CMS -----------------------------------------------------------------
# Create a project at sanity.io/manage, then copy its Project ID here.
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
# Pin the API version to a date (YYYY-MM-DD) for stable, reproducible queries.
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"
# Read token for authenticated/preview content — server-only.
SANITY_API_READ_TOKEN=""
# Optional — only needed to enable the /api/revalidate webhook (every page
# already has a 60s ISR floor without it). Any random string — set the same
# value in Sanity's webhook config.
SANITY_REVALIDATE_SECRET=""
# NOT validated by src/env.ts (read directly via process.env). Needed to run
# `scripts/seed-sanity.ts`, and at runtime for the contact form and the admin
# product importer. Create a token with "Editor" permission under the
# project's API settings at sanity.io/manage.
SANITY_API_WRITE_TOKEN=""

# Stripe ---------------------------------------------------------------------
# Publishable key (safe for the browser).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Secret key and webhook signing secret — server-only.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# AI garden visualiser tool ---------------------------------------------------
# Optional — only needed for the /tools/garden-visualiser tool. Without it,
# that one tool shows an "unavailable" state; nothing else is affected.
# Create a key at platform.openai.com.
OPENAI_API_KEY=""
# Optional — signs the anonymous per-visitor usage cookie for that tool. Any
# random string. Falls back to a fixed in-code value if unset (non-critical).
RATE_LIMIT_SECRET=""

# Admin ------------------------------------------------------------------------
# Optional — the one Supabase account allowed into /admin (product URL
# importer). Create a Supabase user with this exact email at
# supabase.com/dashboard (Authentication > Users > Add user) — there's no
# self-signup. Without this set, /admin is unreachable for everyone.
ADMIN_EMAIL=""
